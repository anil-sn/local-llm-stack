#!/usr/bin/env bash
#
# Interactive CLI Chat with Local LLM
# Uses llama-cli for terminal-based conversation
# Configuration loaded from .env (generated from config.yaml)
#
# DEPRECATED: Use 'llm-stack chat interactive' instead
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Show deprecation notice
echo "⚠️  This script is deprecated. Use the new CLI instead:"
echo "   llm-stack chat interactive"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Load configuration from .env
source "$SCRIPT_DIR/../scripts/load-env.sh"

echo "╔══════════════════════════════════════════════════════════╗"
echo "║     Local LLM Interactive CLI Chat                       ║"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""

# Configuration from .env (command line args override)
MODEL="${1:-$MODEL_PATH}"
CONTEXT="${2:-$CONTEXT_SIZE}"
THREADS_ARG="${3:-}"

# Detect threads (cross-platform)
if [ -z "$THREADS_ARG" ]; then
    if command -v nproc &> /dev/null; then
        THREADS_ARG="$(nproc)"
    elif command -v sysctl &> /dev/null; then
        THREADS_ARG="$(sysctl -n hw.ncpu)"
    else
        THREADS_ARG="4"
    fi
fi

# Check model exists
if [ ! -f "$MODEL" ]; then
    echo "❌ Model not found: $MODEL"
    echo ""
    echo "📥 Download with:"
    echo "   ./bin/models download $ACTIVE_MODEL"
    exit 1
fi

# Check for llama-cli
if ! command -v llama-cli &> /dev/null; then
    echo "❌ llama-cli not found"
    echo ""
    echo "Install llama.cpp:"
    echo "   ./bin/install.sh"
    exit 1
fi

echo "📦 Model: $MODEL"
echo "🧠 Context: $CONTEXT tokens"
echo "🧵 Threads: $THREADS_ARG"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "💬 Chat Mode: Interactive"
echo "   Type your message and press Enter"
echo "   Type '/exit' or '/quit' to end conversation"
echo "   Type '/clear' to clear conversation history"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# System prompt
SYSTEM_PROMPT="You are a helpful, harmless, and honest AI assistant.

**Guidelines:**
- Think through problems step-by-step before answering
- Provide accurate, well-reasoned responses
- Write clean, working code with explanations when asked
- Admit uncertainty when you don't know something
- Respond ONLY in English

**Tone:**
- Professional, friendly, and approachable
- Use clear, concise language"

# Run llama-cli in interactive mode
llama-cli \
    -m "$MODEL" \
    --ctx-size "$CONTEXT" \
    --threads "$THREADS_ARG" \
    --threads-batch "$THREADS_ARG" \
    -n 2048 \
    --temp "$TEMPERATURE" \
    --top-p "$TOP_P" \
    --repeat-penalty "$REPEAT_PENALTY" \
    -ngl "$GPU_LAYERS" \
    --flash-attn "$FLASH_ATTN" \
    --reasoning-format "$REASONING_FORMAT" \
    --reasoning-budget "$REASONING_BUDGET" \
    --prompt "$SYSTEM_PROMPT" \
    --interactive-first \
    --color
