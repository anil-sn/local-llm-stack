#!/usr/bin/env bash
#
# Interactive CLI Chat with Qwen3.5-35B-A3B
# Uses llama-cli for terminal-based conversation
#

set -e

echo "╔══════════════════════════════════════════════════════════╗"
echo "║     Qwen3.5-35B-A3B Interactive CLI Chat                 ║"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""

# Configuration
MODEL="${1:-$HOME/models/Qwen3.5-35B-A3B-UD-Q4_K_XL.gguf}"
CONTEXT="${2:-131072}"
THREADS="${3:-$(sysctl -n hw.ncpu)}"

# Check model exists
if [ ! -f "$MODEL" ]; then
    echo "❌ Model not found: $MODEL"
    echo ""
    echo "Download with:"
    echo "  ./bin/download-model.sh"
    exit 1
fi

# Check for llama-cli
if ! command -v llama-cli &> /dev/null; then
    echo "❌ llama-cli not found"
    echo ""
    echo "Install llama.cpp:"
    echo "  brew install llama.cpp"
    exit 1
fi

echo "📦 Model: $MODEL"
echo "🧠 Context: $CONTEXT tokens"
echo "🧵 Threads: $THREADS"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "💬 Chat Mode: Interactive"
echo "   Type your message and press Enter"
echo "   Type '/exit' or '/quit' to end conversation"
echo "   Type '/clear' to clear conversation history"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# System prompt
SYSTEM_PROMPT="You are a helpful, harmless, and honest AI assistant powered by Qwen3.5-35B-A3B.

**Guidelines:**
- Think through problems step-by-step before answering
- Provide accurate, well-reasoned responses
- Write clean, working code with explanations when asked
- Admit uncertainty when you don't know something
- Respond ONLY in English

**Tone:**
- Professional, friendly, and approachable
- Use clear, concise language"

# Run llama-cli in interactive mode
llama-cli \
    -m "$MODEL" \
    --ctx-size "$CONTEXT" \
    --threads "$THREADS" \
    --threads-batch "$THREADS" \
    -n 2048 \
    --temp 0.7 \
    --top-p 0.9 \
    --repeat-penalty 1.1 \
    -ngl 999 \
    --flash-attn auto \
    --reasoning-format none \
    --reasoning-budget 0 \
    --prompt "$SYSTEM_PROMPT" \
    --interactive-first \
    --color
