#!/usr/bin/env bash
#
# Local LLM Agent Wrapper - Auto-activates venv and runs agent
#
# DEPRECATED: Use 'llm-stack chat agent' instead
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
VENV_DIR="$PROJECT_ROOT/.venv"

# Show deprecation notice
echo "⚠️  This script is deprecated. Use the new CLI instead:"
echo "   llm-stack chat agent"
echo ""

# Activate venv if it exists
if [ -d "$VENV_DIR" ]; then
    source "$VENV_DIR/bin/activate"
fi

# Run agent with all arguments
python "$PROJECT_ROOT/src/python/agent.py" "$@"
