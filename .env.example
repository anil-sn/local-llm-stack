# Qwen3.5-35B-A3B Configuration File
# Copy this file to .env and customize as needed

# ═══════════════════════════════════════════════════════════
# MODEL CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Model name and location
MODEL_NAME="Qwen3.5-35B-A3B-UD-Q4_K_XL.gguf"
MODEL_DIR="$HOME/models"
MODEL_PATH="$MODEL_DIR/$MODEL_NAME"

# HuggingFace repository for model download
HF_REPO="unsloth/Qwen3.5-35B-A3B-GGUF"
HF_FILE="Qwen3.5-35B-A3B-UD-Q4_K_XL.gguf"

# Alternative quantization options (edit download-model.sh to use)
# Q4_K_S, Q5_K_M, Q6_K, Q8_0
MODEL_QUANTIZATION="Q4_K_S"

# ═══════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Server settings
SERVER_PORT="8080"
SERVER_HOST="0.0.0.0"

# Context size (default: 131072, max: 262144)
CONTEXT_SIZE="131072"

# GPU layers (999 = all layers offloaded)
GPU_LAYERS="999"

# CPU threads (auto-detected if not set)
# THREADS=""

# Batch sizes
BATCH_SIZE="512"
UBATCH_SIZE="256"

# Flash attention (auto, on, off)
FLASH_ATTN="auto"

# ═══════════════════════════════════════════════════════════
# REASONING CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Reasoning mode (none, deepseek)
REASONING_FORMAT="none"

# Reasoning budget (-1 = unlimited, 0 = disabled)
REASONING_BUDGET="0"

# Enable thinking in chat template (true, false)
ENABLE_THINKING="false"

# ═══════════════════════════════════════════════════════════
# API CONFIGURATION
# ═══════════════════════════════════════════════════════════

# API base URL
API_BASE_URL="http://localhost:$SERVER_PORT/v1"

# API key (not required by default)
API_KEY="not-needed"

# ═══════════════════════════════════════════════════════════
# PATHS
# ═══════════════════════════════════════════════════════════

# Installation directories
INSTALL_DIR="/usr/local/bin"
BUILD_DIR="$HOME/llama.cpp"

# Log files
LOG_FILE="/tmp/llama-server.log"
PID_FILE="/tmp/llama-server.pid"

# Virtual environment
VENV_DIR="./.venv"

# ═══════════════════════════════════════════════════════════
# BENCHMARK CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Benchmark output directory
BENCHMARK_DIR="./benchmarks"

# Benchmark repetitions
BENCH_REPETITIONS="3"

# ═══════════════════════════════════════════════════════════
# SYSTEM CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Minimum RAM required (GB)
MIN_RAM_GB="16"

# Recommended RAM (GB)
RECOMMENDED_RAM_GB="32"

# Minimum disk space (GB)
MIN_DISK_GB="25"

# ═══════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════

# Enable Web UI (true, false)
ENABLE_WEBUI="true"

# Enable terminal chat (true, false)
ENABLE_CHAT_CLI="true"

# Enable agent mode (true, false)
ENABLE_AGENT="true"

# Enable benchmarks (true, false)
ENABLE_BENCHMARKS="true"

# ═══════════════════════════════════════════════════════════
# ADVANCED OPTIONS
# ═══════════════════════════════════════════════════════════

# Temperature (0.0 - 2.0)
TEMPERATURE="0.7"

# Top P (0.0 - 1.0)
TOP_P="0.9"

# Repeat penalty (1.0 - 2.0)
REPEAT_PENALTY="1.1"

# Max tokens (-1 = unlimited)
MAX_TOKENS="-1"

# ═══════════════════════════════════════════════════════════
# END OF CONFIGURATION
# ═══════════════════════════════════════════════════════════
